---
import { Icon } from 'astro-icon/components';
import social from '@config/social.json';

const socialLinks = Object.entries(social).filter(([_, url]) => url?.trim());

const iconMap: Record<string, string> = {
  facebook: 'mdi:facebook', twitter: 'mdi:twitter', instagram: 'mdi:instagram',
  youtube: 'mdi:youtube', linkedin: 'mdi:linkedin', github: 'mdi:github',
  reddit: 'mdi:reddit', whatsapp: 'mdi:whatsapp', email: 'mdi:email'
};
---

<section class="relative overflow-hidden">
  <!-- Decorative gradient blobs -->
  <div aria-hidden="true" class="pointer-events-none absolute inset-0 -z-10">
    <div class="absolute -top-24 -left-24 w-80 h-80 rounded-full bg-orange-400/20 dark:bg-orange-500/10 blur-3xl"></div>
    <div class="absolute top-20 -right-24 w-96 h-96 rounded-full bg-indigo-400/20 dark:bg-indigo-500/15 blur-3xl"></div>
    <div class="absolute -bottom-24 left-1/3 w-72 h-72 rounded-full bg-fuchsia-300/10 dark:bg-indigo-400/10 blur-3xl"></div>
  </div>

  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24">
    <div class="grid md:grid-cols-2 gap-12 items-center">
      <!-- Left: Text + CTAs -->
      <div class="text-center md:text-left">
        <span class="inline-flex items-center gap-2 px-3 py-1 rounded-full text-xs font-medium brand-soft-bg mb-5">
          <span class="w-2 h-2 rounded-full bg-orange-500 dark:bg-indigo-400 animate-pulse"></span>
          Welcome to my corner of the web
        </span>

        <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold tracking-tight mb-5 text-gray-900 dark:text-white leading-tight">
          Hi, I'm
          <span class="bg-linear-to-r from-orange-500 to-indigo-500 bg-clip-text text-transparent">
            hieupn
          </span>
          <br />
          <span class="text-gray-700 dark:text-gray-200">I build for the web.</span>
        </h1>

        <p class="text-lg text-gray-600 dark:text-gray-300 max-w-xl mx-auto md:mx-0 mb-8">
          Full-stack developer sharing notes, tutorials, and deep dives on modern web development, edge computing, and everything in between.
        </p>

        <div class="flex flex-wrap gap-3 justify-center md:justify-start mb-8">
          <a
            href="/blog/"
            class="group inline-flex items-center gap-2 px-6 py-3 rounded-lg font-semibold brand-button-solid shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all duration-300"
          >
            <Icon name="mdi:book-open-page-variant" class="w-5 h-5" />
            Read the blog
            <Icon
              name="mdi:arrow-right"
              class="w-4 h-4 group-hover:translate-x-0.5 transition-transform"
            />
          </a>
          <a
            href="/about/"
            class="group inline-flex items-center gap-2 px-6 py-3 rounded-lg font-semibold border-2 brand-button-outline shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all duration-300"
          >
            <Icon name="mdi:account-outline" class="w-5 h-5" />
            About me
            <Icon
              name="mdi:arrow-top-right"
              class="w-4 h-4 group-hover:rotate-12 transition-transform"
            />
          </a>
        </div>

        {socialLinks.length > 0 && (
          <div class="flex gap-3 justify-center md:justify-start">
            {socialLinks.map(([platform, url]) => {
              const isBluesky = (url as string).includes('bsky.app');
              return (
                <a
                  href={url as string}
                  class="w-11 h-11 flex items-center justify-center rounded-lg bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-300 hover:bg-orange-500 dark:hover:bg-indigo-500 hover:text-white transition-all hover:scale-110"
                  aria-label={platform}
                >
                  {isBluesky ? (
                    <svg class="w-5 h-5" viewBox="0 0 512 512" fill="currentColor">
                      <path d="M111.8 62.2C170.2 105.9 233 194.7 256 242.4c23-47.6 85.8-136.4 144.2-180.2c42.1-31.6 110.3-56 110.3 21.8c0 15.5-8.9 130.5-14.1 149.2C478.2 298 412 314.6 353.1 304.5c102.9 17.5 129.1 75.5 72.5 133.5c-107.4 110.2-154.3-27.6-166.3-62.9l0 0c-1.7-4.9-2.6-7.8-3.3-7.8s-1.6 3-3.3 7.8l0 0c-12 35.3-59 173.1-166.3 62.9c-56.5-58-30.4-116 72.5-133.5C100 314.6 33.8 298 15.7 233.1C10.4 214.4 1.5 99.4 1.5 83.9c0-77.8 68.2-53.4 110.3-21.8z"/>
                    </svg>
                  ) : (
                    <Icon name={iconMap[platform] || 'mdi:link'} class="w-5 h-5" />
                  )}
                </a>
              );
            })}
          </div>
        )}
      </div>

      <!-- Right: Visual card -->
      <div class="relative">
        <div class="relative mx-auto w-64 h-64 md:w-80 md:h-80">
          <!-- Rotating gradient ring -->
          <div class="absolute inset-0 rounded-full brand-gradient-bg opacity-80 blur-xl"></div>
          <div class="absolute inset-2 rounded-full bg-white dark:bg-gray-900"></div>
          <div class="absolute inset-0 rounded-full brand-gradient-bg opacity-90 p-1">
            <div class="w-full h-full rounded-full bg-white dark:bg-gray-900 flex items-center justify-center">
              <span class="text-7xl md:text-8xl font-extrabold bg-linear-to-br from-orange-500 to-indigo-500 bg-clip-text text-transparent select-none">
                h
              </span>
            </div>
          </div>

          <!-- Floating tags -->
          <div class="absolute -top-4 -left-4 px-3 py-1.5 rounded-full bg-white dark:bg-gray-800 shadow-lg text-xs font-semibold text-gray-700 dark:text-gray-200 border brand-border-soft">
            <span class="brand-accent">#</span> Developing
          </div>
          <div class="absolute top-10 -right-6 px-3 py-1.5 rounded-full bg-white dark:bg-gray-800 shadow-lg text-xs font-semibold text-gray-700 dark:text-gray-200 border brand-border-soft">
            <span class="brand-accent">#</span> Deploying
          </div>
          <div class="absolute -bottom-3 left-6 px-3 py-1.5 rounded-full bg-white dark:bg-gray-800 shadow-lg text-xs font-semibold text-gray-700 dark:text-gray-200 border brand-border-soft">
            <span class="brand-accent">#</span> Writing
          </div>
          <div class="absolute bottom-14 -right-2 px-3 py-1.5 rounded-full bg-white dark:bg-gray-800 shadow-lg text-xs font-semibold text-gray-700 dark:text-gray-200 border brand-border-soft">
            <span class="brand-accent">#</span> Sharing
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
