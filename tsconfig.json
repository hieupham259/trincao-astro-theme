{
	"extends": "astro/tsconfigs/strict",
	"include": [
		".astro/types.d.ts",
		"**/*",
		"./worker-configuration.d.ts"
	],
	"exclude": [
		"dist"
	],
	"compilerOptions": {
		"baseUrl": ".",
		"paths": {
			"@components/*": [
				"src/layouts/components/*"
			],
			"@layouts/*": [
				"src/layouts/*"
			],
			"@config/*": [
				"src/config/*"
			],
			"@utils/*": [
				"src/utils/*"
			],
			"@styles/*": [
				"src/styles/*"
			],
			"@assets/*": [
				"src/assets/*"
			]
		}
	}
}